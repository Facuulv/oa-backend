# OA! backend - copy to .env and adjust

# Server
PORT=4000
NODE_ENV=development

# Database (MySQL)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_DATABASE=sistema_oa
DB_PORT=3306

# JWT (mínimo 32 caracteres)
JWT_SECRET=change_me_min_32_chars_long_secret_key_here!!

# CORS (comma-separated extra origins)
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=

# Cookie de sesión admin (JWT httpOnly). Opcional: ADMIN_SESSION_COOKIE_NAME, ADMIN_SESSION_COOKIE_SAMESITE (lax|strict|none), ADMIN_SESSION_COOKIE_PATH, ADMIN_SESSION_COOKIE_DOMAIN, COOKIE_SECURE=true

# Cookie de sesión cliente tienda (JWT httpOnly). Opcional: CLIENT_SESSION_COOKIE_NAME (default oa_client_token), CLIENT_SESSION_COOKIE_SAMESITE, CLIENT_SESSION_COOKIE_PATH, CLIENT_SESSION_COOKIE_DOMAIN

# Rate Limiting (optional overrides)
# RATE_LIMIT_LOGIN_WINDOW_MS=900000
# RATE_LIMIT_LOGIN_MAX=5
# RATE_LIMIT_API_WINDOW_MS=60000
# RATE_LIMIT_API_MAX=100
